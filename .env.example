# ==================== FIREBASE ADMIN ====================
# Firebase Project ID from your Firebase console
FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Private Key - Get from Firebase console -> Project Settings -> Service Accounts
# Replace with your actual private key (keep the \n for line breaks)
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key_here\n-----END PRIVATE KEY-----\n

# Firebase Service Account Email - Get from Firebase console
FIREBASE_CLIENT_EMAIL=your-firebase-adminsdk@project.iam.gserviceaccount.com

# ==================== SERVER ====================
PORT=4000
NODE_ENV=development

# ==================== ADMIN CREDENTIALS ====================
# SECURITY NOTE: These should be set only in development/testing
# NEVER use simple passwords in production. Use strong, unique credentials
ADMIN_CODE=your_secure_admin_code_here
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_password_here
ADMIN_UID=admin-default-uid

# ==================== API KEYS ====================
# Google Cloud API Key - Get from Google Cloud Console
GOOGLE_API_KEY=your_google_api_key_here

# Gemini API Key - Use same as GOOGLE_API_KEY or separate if needed
GEMINI_API_KEY=your_gemini_api_key_here

# Model configuration for Gemini
GEMINI_MODEL=gemini-2.5-flash

# ==================== ML SERVICE ====================
# URL where your ML/Python service is running
ML_SERVICE_URL=http://localhost:5001

# ==================== CORS ====================
# Set to true only in development with trusted environments
# In production, list specific allowed origins
CORS_ALLOW_ALL=false
CLIENT_ORIGIN=http://localhost:3000

# Optional: Comma-separated list of allowed origins (used when CORS_ALLOW_ALL=false)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,https://yourdomain.com

# ==================== DATABASE ====================
# MongoDB connection string (if using MongoDB)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/your_database
